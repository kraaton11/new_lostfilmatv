<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="100dp"
    android:height="100dp"
    android:viewportWidth="100"
    android:viewportHeight="100">
    
    <!-- Background with rounded corners -->
    <path
        android:pathData="M0,0 L100,0 L100,100 L0,100 Z"
        android:fillColor="#3B7DD8" />
    <!-- Rounded corners simulated via clip? Not needed for simple icon -->
    
    <!-- Monogram LF - letters separated -->
    <group>
        <!-- Letter L -->
        <!-- Vertical line of L -->
        <path
            android:pathData="M20,20 L20,80"
            android:strokeColor="#ffffff"
            android:strokeWidth="15"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <!-- Horizontal bottom of L -->
        <path
            android:pathData="M20,80 L40,80"
            android:strokeColor="#ffffff"
            android:strokeWidth="15"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        
        <!-- Letter F -->
        <!-- Vertical line of F -->
        <path
            android:pathData="M60,20 L60,80"
            android:strokeColor="#ffffff"
            android:strokeWidth="15"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <!-- Top horizontal of F -->
        <path
            android:pathData="M60,20 L80,20"
            android:strokeColor="#ffffff"
            android:strokeWidth="15"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <!-- Middle horizontal of F -->
        <path
            android:pathData="M60,50 L77,50"
            android:strokeColor="#ffffff"
            android:strokeWidth="15"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
    </group>
</vector>